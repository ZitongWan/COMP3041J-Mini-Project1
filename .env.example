# ============================================================
# Campus Buzz - Environment variables (example)
# ============================================================
# Copy this file to `.env` and update the values as needed.
#
# Setup notes:
#   1. After deploying FC functions, you can configure URLs here instead of hardcoding them in s.yaml
#   2. docker-compose will read SUBMISSION_EVENT_FN_URL from this file
#   3. Data Service needs to be exposed publicly (e.g. via ngrok or localtunnel)
# ============================================================

# HTTP trigger URL for the FC Submission Event Function
# Get this from the deployment output (s.yaml / s deploy)
SUBMISSION_EVENT_FN_URL=http://host.docker.internal:9001

# Public URL for the Data Service (expose local port 5002 using ngrok/localtunnel)
# Example: https://xxxx.ngrok-free.dev
# DATA_SERVICE_URL=https://your-tunnel-url.ngrok-free.dev
