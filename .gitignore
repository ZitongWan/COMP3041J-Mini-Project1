# ==============================================================
# Campus Buzz - .gitignore
# ==============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
ENV/
.venv/

# 环境变量（包含密钥）
.env

# SQLite 数据库
*.db

# FC 函数本地安装的依赖（pip install -t . 产生的文件）
serverless/*/flask/
serverless/*/requests/
serverless/*/urllib3/
serverless/*/certifi/
serverless/*/charset_normalizer/
serverless/*/idna/
serverless/*/bin/
serverless/*/*.dist-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
