# ==============================================================
# Campus Buzz - .gitignore
# ==============================================================

# Python cache / compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
ENV/
.venv/

# Environment variables (may contain secrets)
.env

# SQLite database files
*.db

# FC function local dependencies (generated by `pip install -t .`)
serverless/*/flask/
serverless/*/requests/
serverless/*/urllib3/
serverless/*/certifi/
serverless/*/charset_normalizer/
serverless/*/idna/
serverless/*/bin/
serverless/*/*.dist-info/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Docker overrides
docker-compose.override.yml

# OS-specific files
.DS_Store
Thumbs.db
